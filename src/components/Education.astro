---
import { LI, liSrc, eyebrowText } from '../lib/data';
import { getContent } from '../lib/content';
const education = (await getContent(Astro)).education || {};

// Supports multiple entries via `schools[]`. Falls back to the legacy single-degree
// shape ({ degree, institution, dateRange, highlights }) so older content still renders.
const schools = Array.isArray(education.schools) && education.schools.length
  ? education.schools
  : (education.degree || education.institution || education.highlights?.length)
    ? [{ degree: education.degree, institution: education.institution, dateRange: education.dateRange, highlights: education.highlights }]
    : [];
---
<section id="education" class="py-20 md:py-28 px-6 scroll-mt-16">
  <div class="max-w-[1100px] mx-auto">
    {(education.label || education.heading) && (
      <div class="reveal">
        {education.label && <p class="eyebrow-num text-[14px] font-mono text-accent tracking-[0.12em] uppercase mb-3">{eyebrowText(education.label)}</p>}
        {education.heading && (
          <h2 class="font-display text-[32px] md:text-[44px] font-bold text-ink mb-10 tracking-[-0.01em]">
            {education.heading}
          </h2>
        )}
      </div>
    )}

    {schools.length > 0 && (
      <div class="flex flex-col gap-6">
        {schools.map((school: any) => {
          const highlights = school.highlights || [];
          return (
            <div class="reveal card-glow bg-surface-raised rounded-[8px] p-7 md:p-9">
              {(school.degree || school.institution || school.dateRange) && (
                <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-5">
                  <div>
                    {school.degree && <h3 class="font-display text-[22px] font-bold text-ink m-0">{school.degree}</h3>}
                    {school.institution && <p class="text-[17px] text-ink-secondary m-0 mt-1">{school.institution}</p>}
                  </div>
                  {school.dateRange && <span class="text-[14px] text-ink-tertiary font-mono whitespace-nowrap" set:html={school.dateRange} />}
                </div>
              )}

              {highlights.length > 0 && (
                <div class="grid sm:grid-cols-2 gap-3">
                  {highlights.map((h: any) => (
                    <div class={`flex items-center gap-3 p-3.5 rounded-[6px] ${h.featured ? 'bg-accent-wash' : 'bg-surface-sunken'}`}>
                      {h.icon && <lord-icon src={liSrc(h.icon)} trigger="morph" colors={LI.dark} class="li-lg"></lord-icon>}
                      {h.text && <span class="text-[15px] text-ink font-medium">{h.text}</span>}
                    </div>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </div>
    )}
  </div>
</section>
