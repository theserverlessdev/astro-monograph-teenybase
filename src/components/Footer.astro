---
import { LI, liSrc } from '../lib/data';
import { getContent } from '../lib/content';
import { DEMO_MODE } from '../lib/demo';
const content = await getContent(Astro);
const site = content.site || {};
const contact = content.contact || {};
const social = site.social || [];
const footer = contact.footer || {};
---
<footer class="py-8 px-6 bg-surface-sunken border-t border-border overflow-hidden">
  <div class="max-w-[1200px] mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-[14px] text-ink-tertiary">
    {footer.copyright && (
      <p class="m-0 text-center sm:text-left">&copy; <span set:html={footer.copyright} /> {footer.iconsAttribution && <>Icons by <a href={footer.iconsUrl || '#'} target="_blank" rel="noopener" class="text-ink-tertiary hover:text-accent transition-colors no-underline">{footer.iconsAttribution}</a>.</>}</p>
    )}
    {social.length > 0 && (
      <div class="flex items-center gap-3 sm:gap-5 flex-wrap justify-center sm:justify-end">
        {social.map((s: any) => (
          <a href={s.url} target="_blank" rel="noopener" class="inline-flex items-center gap-1 sm:gap-1.5 text-ink-tertiary hover:text-accent transition-colors no-underline font-mono text-[11px] sm:text-[13px] uppercase tracking-[0.08em]">
            {s.icon && <lord-icon src={liSrc(s.icon)} trigger="morph" colors={LI.dark} class="li-sm"></lord-icon>}
            {s.label}
          </a>
        ))}
      </div>
    )}
  </div>
  <div class="max-w-[1200px] mx-auto mt-4 pt-4 border-t border-border/60 text-center">
    <p class="m-0 text-[12px] text-ink-tertiary font-mono">
      Built with
      <a href="https://astro.build" target="_blank" rel="noopener" class="text-ink-tertiary hover:text-accent transition-colors no-underline">Astro</a>
      and
      <a href="https://teenybase.com" target="_blank" rel="noopener" class="text-ink-tertiary hover:text-accent transition-colors no-underline">teenybase</a>
      <span class="mx-1">·</span>
      <a href="/projects" class="text-ink-tertiary hover:text-accent transition-colors no-underline">Projects</a>
      <span class="mx-1">·</span>
      <a href="/cv" class="text-ink-tertiary hover:text-accent transition-colors no-underline">CV</a>
      {DEMO_MODE && (
        <>
          <span class="mx-1.5 opacity-50">·</span>
          <a href="/admin" class="text-ink-tertiary hover:text-accent transition-colors no-underline">Admin</a>
        </>
      )}
    </p>
  </div>
</footer>
