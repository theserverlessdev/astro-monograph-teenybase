---
import { load, LI, liSrc } from '../lib/data';
const skills = load('skills.yaml');
const categories = skills.categories || [];
---
<section id="skills" class="py-20 md:py-28 px-6 bg-surface scroll-mt-16">
  <div class="max-w-[960px] mx-auto">
    {(skills.label || skills.heading) && (
      <div class="reveal">
        {skills.label && <p class="text-[14px] font-mono text-accent tracking-[0.12em] uppercase mb-3">{skills.label}</p>}
        {skills.heading && (
          <h2 class="font-display text-[32px] md:text-[44px] font-bold text-ink mb-12 tracking-[-0.01em]">
            {skills.heading}
          </h2>
        )}
      </div>
    )}

    {categories.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {categories.map((cat: any, i: number) => (
          <div class={`reveal ${i % 2 === 1 ? 'delay-1' : ''} card-glow bg-surface-sunken rounded-[8px] p-6`}>
            <div class="flex items-center gap-3 mb-4">
              {cat.icon && <lord-icon src={liSrc(cat.icon)} trigger="morph" colors={LI.dark} class="li-xl"></lord-icon>}
              {cat.name && <h3 class="font-mono text-[14px] font-medium text-accent m-0 uppercase tracking-[0.08em]">{cat.name}</h3>}
            </div>
            {cat.items?.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {cat.items.map((t: string) => (
                  <span class="inline-block px-3 py-1.5 text-[14px] font-medium rounded-[4px] bg-accent-wash text-accent font-mono">{t}</span>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>
