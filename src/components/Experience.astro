---
import { load } from '../lib/data';
const experience = load('experience.yaml');
const jobs = experience.jobs || [];
---
<section id="experience" class="py-20 md:py-28 px-6 bg-surface scroll-mt-16">
  <div class="max-w-[960px] mx-auto">
    {(experience.label || experience.heading) && (
      <div class="reveal">
        {experience.label && <p class="text-[14px] font-mono text-accent tracking-[0.12em] uppercase mb-3">{experience.label}</p>}
        {experience.heading && (
          <h2 class="font-display text-[32px] md:text-[44px] font-bold text-ink mb-12 tracking-[-0.01em]">
            {experience.heading}
          </h2>
        )}
      </div>
    )}

    {jobs.length > 0 && (
      <div class="border-l-2 border-accent/20">
        {jobs.map((job: any, i: number) => (
          <div class={`reveal flex ${i < jobs.length - 1 ? 'pb-14' : ''}`}>
            <div class="w-3 h-3 rounded-full bg-accent ring-[4px] ring-surface -ml-[7px] mt-[10px] shrink-0"></div>
            <div class="pl-6 min-w-0 flex-1">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                <div>
                  {job.company && <h3 class="font-display text-[22px] font-bold text-ink m-0">{job.url ? <a href={job.url} target="_blank" rel="noopener" class="text-ink no-underline hover:text-accent transition-colors">{job.company}</a> : job.company}</h3>}
                  {job.role && <p class="text-[16px] text-accent font-medium m-0">{job.role}</p>}
                </div>
                {job.dateRange && <span class="text-[14px] text-ink-tertiary font-mono" set:html={job.dateRange} />}
              </div>
              {job.location && <p class="text-[14px] text-ink-tertiary mt-0 mb-3">{job.location}</p>}
              {job.description && <p class="text-[17px] text-ink-secondary leading-[1.7] mt-0 mb-4">{job.description}</p>}
              {job.tech?.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {job.tech.map((t: string) => (
                    <span class="inline-block px-2.5 py-1 text-[13px] font-medium rounded bg-accent-wash text-accent font-mono">{t}</span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
