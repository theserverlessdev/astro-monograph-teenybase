---
// /projects — a full index of every project (the home section only teases the
// featured few). Reads the same CMS `projects` content; each card links to its
// /projects/<slug> detail page.
export const prerender = false;
import PageLayout from '../../layouts/PageLayout.astro';
import { getContent } from '../../lib/content';
import { projectSlug } from '../../lib/slug';

const content = await getContent(Astro);
const projects = content.projects || {};
const items: any[] = projects.enabled !== false ? projects.items || [] : [];

const statusColors: Record<string, string> = {};
(projects.statuses || []).forEach((s: any) => { if (s.color) statusColors[s.label] = s.color; });
const defaultColor = '#6B7280';
---
<PageLayout
  title="Projects — Astro Monograph"
  description="Things I've built — products, tools, and experiments across infrastructure, AI, and the web."
  ogImage="/og/page/projects.png"
>
  <main class="pt-28 pb-20 px-6 min-h-screen">
    <div class="max-w-[1100px] mx-auto">
      <a href="/#projects" class="inline-block text-[14px] font-mono text-accent hover:text-accent-light no-underline mb-6">← Home</a>
      <p class="eyebrow-num text-[14px] font-mono text-accent tracking-[0.12em] uppercase mb-3">Projects</p>
      <h1 class="font-display text-[32px] md:text-[44px] font-bold text-ink mb-3 tracking-[-0.01em]">Everything I've built</h1>
      <p class="text-[17px] text-ink-secondary mb-10 max-w-[640px]">Products, open-source tools, and experiments. {items.length} in total — click any for the full write-up.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {items.map((p: any) => {
          const color = statusColors[p.status] || defaultColor;
          const slug = projectSlug(p);
          return (
            <a href={`/projects/${slug}`} class="group card-glow bg-surface-raised rounded-[8px] flex flex-col overflow-hidden no-underline">
              {p.image && (
                <div class="relative h-40 shrink-0 overflow-hidden bg-surface-sunken">
                  <img src={p.image} alt={`${p.title} screenshot`} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-[650ms] ease-out group-hover:scale-[1.07]" />
                  <div class="absolute inset-0 bg-gradient-to-t from-surface-raised via-surface-raised/15 to-transparent"></div>
                  {p.status && (
                    <span class="absolute top-3 right-3 z-10 inline-block px-2.5 py-1 text-[11px] sm:text-[12px] font-medium rounded font-mono uppercase whitespace-nowrap backdrop-blur-sm shadow-sm" style={`color: ${color}; background: ${color}26;`}>{p.status}</span>
                  )}
                </div>
              )}
              <div class={`flex flex-col flex-1 ${p.image ? 'p-6 pt-5' : 'p-6'}`}>
                {p.title && <h2 class="font-display text-[20px] font-bold text-ink m-0 mb-1 group-hover:text-accent transition-colors">{p.title}</h2>}
                {p.subtitle && <p class="text-[14px] text-accent font-medium mb-2.5 mt-0">{p.subtitle}</p>}
                {p.description && <p class="text-[15px] text-ink-secondary leading-[1.6] mt-0 mb-4 line-clamp-3">{p.description}</p>}
                <div class="mt-auto flex items-center justify-between gap-3">
                  {p.tech?.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {p.tech.slice(0, 3).map((t: string) => (
                        <span class="inline-block px-2 py-0.5 text-[12px] font-medium rounded bg-accent-wash text-accent font-mono">{t}</span>
                      ))}
                    </div>
                  )}
                  <span class="text-[13px] font-medium text-accent shrink-0 whitespace-nowrap">Details →</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </main>
</PageLayout>

<style>
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
