---
export const prerender = false;
import { marked } from 'marked';
import PageLayout from '../../layouts/PageLayout.astro';
import { getPostBySlug, formatDate } from '../../lib/blog';

const { slug } = Astro.params;
const post = slug ? await getPostBySlug((Astro.locals as any).cfContext, slug) : null;

if (!post) {
  return new Response('Not found', { status: 404 });
}

marked.setOptions({ gfm: true, breaks: false });
const html = await marked.parse(post.body || '');
const cover = post.cover_image && /^https?:\/\//.test(post.cover_image) ? post.cover_image : null;
---
<PageLayout title={`${post.title} — Astro Monograph`} description={post.excerpt || post.title}>
  <main class="pt-28 pb-20 px-6 min-h-screen">
    <article class="max-w-[720px] mx-auto">
      <a href="/blog" class="inline-block text-[14px] font-mono text-accent hover:text-accent-light no-underline mb-8">← All posts</a>

      <div class="flex items-center gap-3 mb-3 flex-wrap">
        {post.published_at && (
          <time class="text-[13px] font-mono text-ink-tertiary" datetime={post.published_at}>{formatDate(post.published_at)}</time>
        )}
        {post.ai_generated ? (
          <span class="inline-flex items-center text-[11px] font-mono uppercase tracking-[0.06em] text-accent bg-accent-wash rounded px-1.5 py-0.5">AI-assisted</span>
        ) : null}
        {post.tags?.map((t) => <span class="text-[12px] font-mono text-accent">#{t}</span>)}
      </div>

      <h1 class="font-display text-[32px] md:text-[40px] font-bold text-ink m-0 mb-6 tracking-[-0.01em] leading-[1.15]">{post.title}</h1>

      {post.ai_generated ? (
        <div class="mb-6 rounded-[8px] border border-border bg-surface-sunken px-4 py-3 text-[14px] text-ink-secondary leading-[1.6]">
          <strong class="text-ink font-semibold">AI-assisted post.</strong> Written with AI assistance under my direction and review.
        </div>
      ) : null}

      {cover && <img src={cover} alt={post.title} class="w-full rounded-[8px] border border-border mb-8" loading="lazy" />}

      <div class="post-body" set:html={html}></div>
    </article>
  </main>
</PageLayout>

<style>
  .post-body :global(h2) { font-family: var(--font-display, inherit); font-size: 24px; font-weight: 700; color: var(--color-ink); margin: 2rem 0 0.75rem; }
  .post-body :global(h3) { font-size: 19px; font-weight: 600; color: var(--color-ink); margin: 1.5rem 0 0.5rem; }
  .post-body :global(p) { font-size: 17px; line-height: 1.8; color: var(--color-ink-secondary); margin: 0 0 1.1rem; }
  .post-body :global(ul), .post-body :global(ol) { color: var(--color-ink-secondary); font-size: 17px; line-height: 1.8; padding-left: 1.4rem; margin: 0 0 1.1rem; }
  .post-body :global(li) { margin: 0.3rem 0; }
  .post-body :global(a) { color: var(--color-accent); text-decoration: underline; }
  .post-body :global(strong) { color: var(--color-ink); font-weight: 600; }
  .post-body :global(code) { font-family: ui-monospace, monospace; font-size: 0.9em; background: var(--color-accent-wash); color: var(--color-accent); padding: 0.15em 0.4em; border-radius: 4px; }
  .post-body :global(pre) { background: var(--color-surface-sunken); border: 1px solid var(--color-border); border-radius: 8px; padding: 1rem 1.25rem; overflow-x: auto; margin: 0 0 1.25rem; }
  .post-body :global(pre code) { background: none; color: var(--color-ink); padding: 0; }
  .post-body :global(blockquote) { border-left: 3px solid var(--color-accent); padding-left: 1rem; margin: 0 0 1.1rem; color: var(--color-ink-tertiary); }
  .post-body :global(img) { max-width: 100%; border-radius: 8px; border: 1px solid var(--color-border); }
</style>
