---
export const prerender = false;
import '../../styles/global.css';
// The admin is a client-rendered SPA (auth happens in the browser against the
// same-origin teenybase API). We ship a minimal SSR shell + mount point.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin — Astro Monograph</title>
    <meta name="robots" content="noindex, nofollow" />
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Lordicon: live icon previews in the content editor -->
    <script is:inline src="https://cdn.lordicon.com/lordicon.js" defer></script>
  </head>
  <body class="bg-surface text-ink">
    <div id="admin-root" class="adm-root">
      <div class="adm-boot">Loading admin…</div>
    </div>
    <script>
      import { AdminApp } from '../../lib/admin/app';
      const root = document.getElementById('admin-root');
      if (root) new AdminApp(root);
    </script>
  </body>
</html>

<style is:global>
  :root {
    --adm-radius: 10px;
  }
  .adm-root { min-height: 100vh; }
  .adm-boot { display: grid; place-items: center; min-height: 100vh; color: var(--color-ink-tertiary); font-family: var(--font-mono, monospace); }

  /* Buttons */
  .adm-btn { display: inline-flex; align-items: center; gap: .4rem; padding: .55rem 1rem; border-radius: 8px; border: 1px solid var(--color-border); background: var(--color-surface-raised); color: var(--color-ink); font: inherit; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; white-space: nowrap; transition: all .15s; }
  .adm-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .adm-btn-primary { background: var(--color-accent); color: var(--color-ink-on-dark, #fff); border-color: var(--color-accent); }
  .adm-btn-primary:hover { filter: brightness(1.08); color: var(--color-ink-on-dark, #fff); }
  .adm-btn-block { width: 100%; justify-content: center; margin-top: .5rem; }
  .adm-danger-btn { color: #c0392b; border-color: #e7b9b3; }
  .adm-danger-btn:hover { background: #c0392b; color: #fff; border-color: #c0392b; }

  /* Auth */
  .adm-auth { min-height: 100vh; display: grid; place-items: center; padding: 2rem; }
  .adm-auth-card { width: 100%; max-width: 380px; background: var(--color-surface-raised); border: 1px solid var(--color-border); border-radius: var(--adm-radius); padding: 2rem; display: flex; flex-direction: column; }
  .adm-auth-title { font-family: var(--font-display, inherit); font-size: 24px; font-weight: 700; margin: 0 0 .25rem; }
  .adm-auth-sub { color: var(--color-ink-secondary); margin: 0 0 1.25rem; font-size: 14px; }
  .adm-demo-note { background: var(--color-accent-wash); color: var(--color-ink-secondary); border: 1px solid var(--color-border); border-radius: 8px; padding: .65rem .75rem; font-size: 12.5px; line-height: 1.5; margin-bottom: .5rem; }
  .adm-demo-note strong { color: var(--color-accent); }
  .adm-demo-cred { font-family: var(--font-mono, monospace); font-size: 12px; background: var(--color-surface-sunken); color: var(--color-ink); padding: .1em .4em; border-radius: 4px; white-space: nowrap; }

  /* Inputs */
  .adm-label { display: block; font-size: 13px; font-weight: 600; color: var(--color-ink-secondary); margin: .9rem 0 .35rem; }
  .adm-req { color: #c0392b; }
  .adm-input { width: 100%; box-sizing: border-box; padding: .6rem .7rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface); color: var(--color-ink); font: inherit; font-size: 14px; transition: border-color .15s; }
  .adm-input:focus { outline: none; border-color: var(--color-accent); }
  .adm-textarea { min-height: 90px; resize: vertical; line-height: 1.6; }
  .adm-mono { font-family: var(--font-mono, monospace); font-size: 13px; }
  .adm-help { font-size: 12px; color: var(--color-ink-tertiary); margin: .35rem 0 0; }
  .adm-error { background: #fdecea; color: #c0392b; border: 1px solid #f5c6cb; padding: .6rem .75rem; border-radius: 8px; font-size: 13px; margin-bottom: .5rem; }
  .adm-error-inline { color: #c0392b; font-size: 13px; }
  .adm-ok { color: #2d8a56; font-size: 13px; font-weight: 600; }

  /* Shell */
  .adm-shell { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
  .adm-side { border-right: 1px solid var(--color-border); padding: 1.25rem 1rem; display: flex; flex-direction: column; gap: .25rem; background: var(--color-surface-sunken); position: sticky; top: 0; height: 100vh; box-sizing: border-box; }
  .adm-brand { font-family: var(--font-display, inherit); font-weight: 700; font-size: 18px; margin-bottom: 1rem; }
  .adm-brand span { color: var(--color-accent); }
  .adm-nav { display: flex; flex-direction: column; gap: .15rem; }
  .adm-nav-link { display: flex; align-items: center; justify-content: space-between; padding: .5rem .65rem; border-radius: 8px; color: var(--color-ink-secondary); text-decoration: none; font-size: 14px; font-weight: 500; background: none; border: none; cursor: pointer; text-align: left; width: 100%; box-sizing: border-box; }
  .adm-nav-link:hover { background: var(--color-surface-raised); color: var(--color-ink); }
  .adm-active { background: var(--color-accent-wash); color: var(--color-accent); font-weight: 600; }
  .adm-nav-disabled { opacity: .55; }
  .adm-soon { font-size: 10px; text-transform: uppercase; letter-spacing: .05em; background: var(--color-border); color: var(--color-ink-tertiary); padding: .1rem .35rem; border-radius: 4px; }
  .adm-side-foot { margin-top: auto; border-top: 1px solid var(--color-border); padding-top: .5rem; }
  .adm-logout { color: var(--color-ink-tertiary); }
  /* min-width:0 lets the 1fr grid track shrink instead of letting wide content
     (tables, long titles) blow the page out horizontally on narrow screens. */
  .adm-main { padding: 1.75rem 2rem; max-width: 1000px; min-width: 0; }

  /* Topbar (mobile), theme toggle, drawer — desktop defaults */
  .adm-topbar { display: none; }
  .adm-overlay { display: none; }
  .adm-theme-btn { background: none; border: 1px solid var(--color-border); border-radius: 8px; width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; color: var(--color-ink-secondary); flex-shrink: 0; }
  .adm-theme-btn:hover { color: var(--color-accent); border-color: var(--color-accent); }
  .adm-theme-row { justify-content: space-between; }
  .adm-theme-icon { display: inline-flex; }
  .adm-hamburger { display: inline-flex; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 8px; }
  .adm-hamburger span { display: block; width: 22px; height: 2px; background: var(--color-ink); border-radius: 2px; }
  .adm-brand-side { margin-bottom: 1rem; }

  /* Head */
  .adm-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
  .adm-head h1 { font-family: var(--font-display, inherit); font-size: 26px; font-weight: 700; margin: 0; }
  .adm-head-left { display: flex; flex-direction: column; gap: .2rem; }
  .adm-head-actions { display: flex; gap: .5rem; }
  .adm-back { font-size: 13px; color: var(--color-accent); text-decoration: none; }

  /* Table */
  .adm-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .adm-table th { text-align: left; padding: .5rem .6rem; color: var(--color-ink-tertiary); font-size: 12px; text-transform: uppercase; letter-spacing: .04em; border-bottom: 1px solid var(--color-border); }
  .adm-table td { padding: .65rem .6rem; border-bottom: 1px solid var(--color-border); color: var(--color-ink-secondary); }
  .adm-link { color: var(--color-ink); font-weight: 600; text-decoration: none; }
  .adm-link:hover { color: var(--color-accent); }
  .adm-row-actions { text-align: right; white-space: nowrap; }
  .adm-icon-btn { display: inline-block; padding: .25rem .45rem; border-radius: 6px; border: none; background: none; cursor: pointer; text-decoration: none; font-size: 14px; color: var(--color-ink-tertiary); }
  .adm-icon-btn:hover { background: var(--color-surface-sunken); color: var(--color-ink); }
  .adm-danger:hover { color: #c0392b; }

  /* Empty */
  .adm-empty { text-align: center; padding: 3rem 1rem; border: 1px dashed var(--color-border); border-radius: var(--adm-radius); color: var(--color-ink-secondary); display: flex; flex-direction: column; align-items: center; gap: .5rem; }

  /* Form */
  .adm-field { margin-bottom: 1.1rem; }
  .adm-switch { display: inline-flex; align-items: center; gap: .5rem; cursor: pointer; font-size: 14px; font-weight: 500; }
  .adm-switch input { width: 18px; height: 18px; accent-color: var(--color-accent); }
  .adm-save-bar { position: sticky; bottom: 0; padding: .5rem 0; min-height: 1.5rem; background: var(--color-surface); }
  .adm-sub { font-size: 13px; color: var(--color-ink-secondary); margin: .2rem 0 0; max-width: 60ch; }

  /* Nav groups (sidebar) */
  .adm-nav-group { font-size: 10px; text-transform: uppercase; letter-spacing: .07em; color: var(--color-ink-tertiary); font-weight: 700; margin: .9rem .65rem .2rem; }
  .adm-nav-group:first-child { margin-top: 0; }

  /* Color field */
  .adm-color { display: flex; gap: .5rem; align-items: center; }
  .adm-color-swatch { width: 46px; height: 38px; padding: 0; border: 1px solid var(--color-border); border-radius: 8px; background: none; cursor: pointer; flex-shrink: 0; }
  .adm-color-text { flex: 1; font-family: var(--font-mono, monospace); font-size: 13px; }

  /* Icon field + curated picker gallery */
  .adm-icon-field { display: flex; gap: .6rem; align-items: center; }
  .adm-icon-field .adm-input { flex: 1; min-width: 0; }
  .adm-icon-preview { width: 38px; height: 38px; flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface-sunken); box-sizing: border-box; }
  .adm-icon-browse { flex-shrink: 0; padding: .5rem .7rem; font-size: 13px; }
  .adm-icon-gallery { margin-top: .5rem; border: 1px solid var(--color-border); border-radius: 10px; padding: .6rem; background: var(--color-surface-sunken); }
  .adm-icon-gallery[hidden] { display: none; }
  .adm-icon-search { margin-bottom: .5rem; }
  .adm-icon-grid { max-height: 290px; overflow-y: auto; }
  .adm-icon-grid-group { font-size: 10px; text-transform: uppercase; letter-spacing: .07em; color: var(--color-ink-tertiary); font-weight: 700; margin: .55rem .15rem .3rem; }
  .adm-icon-grid-items { display: grid; grid-template-columns: repeat(auto-fill, minmax(74px, 1fr)); gap: .4rem; }
  .adm-icon-cell { display: flex; flex-direction: column; align-items: center; gap: .3rem; padding: .5rem .25rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface-raised); cursor: pointer; color: var(--color-ink-secondary); transition: border-color .15s, color .15s, background .15s; }
  .adm-icon-cell:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .adm-icon-cell-active { border-color: var(--color-accent); background: var(--color-accent-wash); color: var(--color-accent); }
  .adm-icon-cell-preview { width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; }
  .adm-icon-cell-label { font-size: 10.5px; text-align: center; line-height: 1.2; }

  /* Nested group */
  .adm-group { border: 1px solid var(--color-border); border-radius: 10px; padding: .2rem .85rem .6rem; margin-bottom: 1.1rem; background: var(--color-surface-sunken); }
  .adm-group-title { font-size: 12px; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: .04em; margin: .7rem 0 .1rem; }

  /* Repeatable lists */
  .adm-list { display: flex; flex-direction: column; gap: .55rem; margin-bottom: .55rem; }
  .adm-list-item { display: flex; gap: .4rem; align-items: flex-start; }
  .adm-list-item textarea { flex: 1; min-width: 0; min-height: 56px; }
  .adm-list-item .adm-rt-host { flex: 1; min-width: 0; }
  .adm-card { border: 1px solid var(--color-border); border-radius: 10px; background: var(--color-surface-raised); overflow: hidden; }
  .adm-card-head { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: .4rem .35rem .4rem .75rem; background: var(--color-surface-sunken); border-bottom: 1px solid var(--color-border); }
  /* flex:1 + min-width:0 so a long item title ellipsizes instead of forcing the
     card (and the whole page) wider than the viewport. */
  .adm-card-title { flex: 1; min-width: 0; font-weight: 600; font-size: 13.5px; color: var(--color-ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .adm-card-body { padding: .55rem .8rem .15rem; }
  .adm-item-ctrls { display: flex; gap: .05rem; flex-shrink: 0; }
  .adm-add { font-size: 13px; padding: .4rem .85rem; align-self: flex-start; }

  /* Rich-text editor (constrained WYSIWYG) */
  .rt-editor { border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface); overflow: hidden; }
  .rt-editor:focus-within { border-color: var(--color-accent); }
  .rt-toolbar { display: flex; gap: .15rem; padding: .3rem .35rem; border-bottom: 1px solid var(--color-border); background: var(--color-surface-sunken); }
  .rt-btn { min-width: 30px; height: 28px; padding: 0 .45rem; border: 1px solid transparent; border-radius: 6px; background: none; cursor: pointer; color: var(--color-ink-secondary); font-size: 14px; line-height: 1; }
  .rt-btn:hover { background: var(--color-surface-raised); border-color: var(--color-border); color: var(--color-ink); }
  .rt-area { padding: .6rem .7rem; min-height: 60px; font: inherit; font-size: 14px; line-height: 1.6; color: var(--color-ink); outline: none; }
  .rt-area:empty:before { content: attr(data-placeholder); color: var(--color-ink-tertiary); }
  .rt-area a { color: var(--color-accent); text-decoration: underline; }
  .adm-list-item .rt-editor { flex: 1; }

  /* Tags */
  .adm-tags { border: 1px solid var(--color-border); border-radius: 8px; padding: .35rem; background: var(--color-surface); }
  .adm-tags-pills { display: flex; flex-wrap: wrap; gap: .35rem; }
  .adm-pill { display: inline-flex; align-items: center; gap: .3rem; background: var(--color-accent-wash); color: var(--color-accent); border-radius: 6px; padding: .2rem .5rem; font-size: 13px; font-weight: 500; }
  .adm-pill button { border: none; background: none; color: inherit; cursor: pointer; font-size: 14px; line-height: 1; }
  .adm-tags-input { border: none; outline: none; background: none; padding: .3rem .4rem; font: inherit; font-size: 14px; color: var(--color-ink); flex: 1; min-width: 120px; }

  /* Image field */
  .adm-image-drop { font-size: 12px; color: var(--color-ink-tertiary); padding: .5rem; border: 1px dashed var(--color-border); border-radius: 8px; text-align: center; margin-top: .5rem; }
  .adm-image.adm-dragging .adm-image-drop { border-color: var(--color-accent); color: var(--color-accent); }
  .adm-image-preview img { max-width: 220px; border-radius: 8px; border: 1px solid var(--color-border); margin-top: .5rem; }

  /* Tools: Quick Add + Analytics */
  .adm-prose { max-width: 640px; }
  .adm-prose p { color: var(--color-ink-secondary); line-height: 1.6; }
  .adm-prose code { font-family: var(--font-mono, monospace); font-size: .88em; background: var(--color-surface-sunken); padding: .1em .4em; border-radius: 4px; }
  .adm-steps { color: var(--color-ink-secondary); line-height: 1.7; padding-left: 1.2rem; margin: .5rem 0 1rem; }
  .adm-steps li { margin: .35rem 0; }
  .adm-bm { display: inline-block; cursor: grab; font-size: 14px; font-weight: 600; padding: .35rem .85rem; text-decoration: none; color: var(--color-ink-on-dark, #fff); background: var(--color-accent); border-radius: 7px; white-space: nowrap; }
  .adm-bm:active { cursor: grabbing; }
  .adm-copyrow { display: flex; gap: .5rem; flex-wrap: wrap; margin: .75rem 0; }
  .adm-pre { background: var(--color-surface-sunken); border: 1px solid var(--color-border); border-radius: 6px; padding: .75rem; font-size: 11px; line-height: 1.5; overflow-x: auto; white-space: pre-wrap; word-break: break-all; color: var(--color-ink-secondary); }
  .adm-details { margin-top: 1rem; }
  .adm-details summary { cursor: pointer; color: var(--color-ink-tertiary); font-size: 13px; }

  /* Markdown editor */
  .md-editor { border: 1px solid var(--color-border); border-radius: 10px; overflow: hidden; background: var(--color-surface); }
  .md-toolbar { display: flex; align-items: center; gap: .15rem; padding: .35rem .5rem; border-bottom: 1px solid var(--color-border); background: var(--color-surface-sunken); flex-wrap: wrap; }
  .md-toolbar button { min-width: 30px; height: 30px; padding: 0 .4rem; border: 1px solid transparent; border-radius: 6px; background: none; cursor: pointer; color: var(--color-ink-secondary); font-size: 14px; }
  .md-toolbar button:hover { background: var(--color-surface-raised); border-color: var(--color-border); color: var(--color-ink); }
  .md-sep { width: 1px; height: 20px; background: var(--color-border); margin: 0 .25rem; }
  .md-spacer { flex: 1; }
  .md-toggle { font-size: 12px !important; font-weight: 600; }
  .md-panes { display: grid; grid-template-columns: 1fr 1fr; min-height: 360px; }
  .md-input { border: none; outline: none; resize: vertical; padding: 1rem; font-family: var(--font-mono, monospace); font-size: 14px; line-height: 1.7; background: var(--color-surface); color: var(--color-ink); min-height: 360px; }
  .md-preview { padding: 1rem 1.25rem; border-left: 1px solid var(--color-border); overflow-y: auto; max-height: 600px; background: var(--color-surface-raised); }
  .md-editor.md-preview-only .md-input { display: none; }
  .md-editor.md-preview-only .md-preview { border-left: none; }
  .md-editor.md-dragging { outline: 2px dashed var(--color-accent); outline-offset: -2px; }
  .md-drop-hint { display: none; }
  /* Full-page focused writing mode (toggled from the editor toolbar) */
  body.md-fullpage-lock { overflow: hidden; }
  .md-editor.md-fullpage { position: fixed; inset: 0; z-index: 1000; display: flex; flex-direction: column; border: none; border-radius: 0; background: var(--color-surface); }
  .md-editor.md-fullpage .md-panes { flex: 1; min-height: 0; }
  .md-editor.md-fullpage .md-input { height: 100%; min-height: 0; resize: none; overflow: auto; font-size: 15px; line-height: 1.85; padding: 2rem clamp(1rem, 5vw, 4rem); }
  .md-editor.md-fullpage .md-preview { height: 100%; max-height: none; overflow-y: auto; padding: 2rem clamp(1rem, 5vw, 4rem); }
  .md-editor.md-fullpage.md-preview-only .md-preview { max-width: 820px; width: 100%; margin: 0 auto; }
  .md-toolbar .md-fullpage-active { color: var(--color-accent); border-color: var(--color-border); }
  @media (max-width: 820px) {
    .adm-shell { grid-template-columns: 1fr; }
    .adm-topbar { display: flex; align-items: center; justify-content: space-between; gap: .5rem; padding: .5rem .65rem; border-bottom: 1px solid var(--color-border); background: var(--color-surface-sunken); position: sticky; top: 0; z-index: 50; }
    .adm-topbar .adm-brand { margin: 0; font-size: 16px; }
    .adm-side { position: fixed; top: 0; left: 0; height: 100dvh; width: 260px; max-width: 84vw; transform: translateX(-100%); transition: transform .22s ease; z-index: 60; box-shadow: 0 0 30px rgba(0,0,0,.18); overflow-y: auto; }
    .adm-side-open { transform: translateX(0); }
    .adm-overlay { display: block; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 55; opacity: 0; pointer-events: none; transition: opacity .2s; }
    .adm-overlay-show { opacity: 1; pointer-events: auto; }
    .md-panes { grid-template-columns: 1fr; }
    .md-preview { border-left: none; border-top: 1px solid var(--color-border); }
    .md-editor.md-fullpage:not(.md-preview-only) .md-preview { display: none; }
    .adm-main { padding: 1rem; }
    .adm-head { flex-direction: column; align-items: flex-start; gap: .75rem; }
    .adm-head-actions { width: 100%; flex-wrap: wrap; }
    .adm-head-actions .adm-btn { flex: 1; justify-content: center; }
    .md-input { min-height: 240px; }
  }
  @media (min-width: 821px) { .adm-brand-side { display: block; } }

  /* Phones: list tables would overflow, so stack each row into a labelled card
     (labels come from each cell's data-label). */
  @media (max-width: 640px) {
    .adm-table, .adm-table tbody { display: block; width: 100%; }
    .adm-table thead { display: none; }
    .adm-table tr {
      display: block;
      border: 1px solid var(--color-border);
      border-radius: 10px;
      background: var(--color-surface-raised);
      padding: .35rem .85rem;
      margin-bottom: .65rem;
    }
    .adm-table td {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding: .4rem 0;
      border: none;
      border-bottom: 1px solid var(--color-border);
      text-align: right;
      word-break: break-word;
    }
    .adm-table tr td:last-child { border-bottom: none; }
    .adm-table td::before {
      content: attr(data-label);
      flex-shrink: 0;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .04em;
      color: var(--color-ink-tertiary);
      text-align: left;
    }
    .adm-table td.adm-row-actions { justify-content: flex-end; }
    .adm-table td.adm-row-actions::before { content: ""; }
  }

  /* Post body (shared preview typography) */
  .post-body h2 { font-size: 20px; font-weight: 700; margin: 1.5rem 0 .5rem; color: var(--color-ink); }
  .post-body h3 { font-size: 17px; font-weight: 600; margin: 1.2rem 0 .4rem; color: var(--color-ink); }
